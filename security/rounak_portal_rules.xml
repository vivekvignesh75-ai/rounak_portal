<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Portal users see only their own notifications -->
    <record id="rule_portal_notification_own" model="ir.rule">
        <field name="name">Portal: own notifications only</field>
        <field name="model_id" ref="rounak_erp.model_rounak_notification"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <!-- Portal users see only their own notification preferences -->
    <record id="rule_portal_notification_pref_own" model="ir.rule">
        <field name="name">Portal: own notification preferences</field>
        <field name="model_id" ref="rounak_erp.model_rounak_notification_preference"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>
</odoo>
