<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_invoices" name="Rounak Portal Invoices">
        <t t-call="rounak_portal.portal_rounak_layout">
            <div class="rounak-page">
                <h2 class="rounak-page-title">Invoices</h2>

                <div class="rounak-kpi-grid rounak-kpi-grid-sm mb-3">
                    <div class="rounak-kpi-tile">
                        <div class="rounak-kpi-value" t-esc="'AED {:,.2f}'.format(total_due)"/>
                        <div class="rounak-kpi-label">Total Outstanding</div>
                    </div>
                </div>

                <ul class="rounak-tabs">
                    <li t-attf-class="#{status == 'all' and 'active' or ''}">
                        <a href="/my/rounak/invoices?status=all">All</a>
                    </li>
                    <li t-attf-class="#{status == 'due' and 'active' or ''}">
                        <a href="/my/rounak/invoices?status=due">Due</a>
                    </li>
                    <li t-attf-class="#{status == 'overdue' and 'active' or ''}">
                        <a href="/my/rounak/invoices?status=overdue">Overdue</a>
                    </li>
                    <li t-attf-class="#{status == 'paid' and 'active' or ''}">
                        <a href="/my/rounak/invoices?status=paid">Paid</a>
                    </li>
                </ul>

                <table class="table rounak-table">
                    <thead>
                        <tr>
                            <th>Invoice #</th>
                            <th>Date</th>
                            <th>Due Date</th>
                            <th class="text-end">Total</th>
                            <th class="text-end">Amount Due</th>
                            <th>Status</th>
                            <th>PDF</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="invoices" t-as="inv">
                            <tr t-attf-class="#{inv.invoice_date_due and inv.invoice_date_due &lt; today and inv.payment_state not in ('paid','reversed') and 'rounak-row-overdue' or ''}">
                                <td t-esc="inv.name"/>
                                <td t-esc="inv.invoice_date" t-options="{'widget': 'date'}"/>
                                <td t-esc="inv.invoice_date_due" t-options="{'widget': 'date'}"/>
                                <td class="text-end">
                                    <t t-esc="inv.amount_total"
                                       t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}"/>
                                </td>
                                <td class="text-end">
                                    <t t-esc="inv.amount_residual"
                                       t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}"/>
                                </td>
                                <td>
                                    <span class="badge rounak-badge-status"
                                          t-esc="dict(inv._fields['payment_state'].selection).get(inv.payment_state)"/>
                                </td>
                                <td>
                                    <a t-attf-href="/my/invoices/#{inv.id}?report_type=pdf"
                                       class="btn btn-sm rounak-btn-outline" title="PDF">
                                        <i class="fa fa-download"/>
                                    </a>
                                </td>
                            </tr>
                        </t>
                        <tr t-if="not invoices">
                            <td colspan="7" class="text-muted text-center">No invoices found</td>
                        </tr>
                    </tbody>
                </table>

                <div class="text-center" t-if="pager">
                    <t t-call="portal.pager"/>
                </div>
            </div>
        </t>
    </template>
</odoo>
